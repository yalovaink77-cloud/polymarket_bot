POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_passphrase_here
POLY_PRIVATE_KEY=your_private_key_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

MAX_POSITION_PCT=0.05
MAX_CORRELATED_PCT=0.15
CAPITAL_TOTAL_USD=1000.0

IMBALANCE_HIGH=1.8
IMBALANCE_LOW=0.55
DEPTH_RATIO_MIN=0.4
ZSCORE_THRESHOLD=2.7
OVERREACTION_THRESHOLD=3.0
SPREAD_ZSCORE_THRESHOLD=2.5
TOP3_CONCENTRATION_MIN=0.70
COMPOSITE_SCORE_MIN=0.75

ENV=development
REQUIRE_TELEGRAM_APPROVAL=false
AUTO_SWITCH_TO_LIVE=false
DRY_RUN_EVAL_HORIZON_SEC=300
DRY_RUN_MIN_TRADES=50
DRY_RUN_MIN_WIN_RATE=0.60
DRY_RUN_MIN_NET_PNL_USD=20.0
DRY_RUN_PNL_FLOOR_PRICE=0.05
DRY_RUN_STATE_FILE=logs/dry_run_stats.json
LOG_LEVEL=INFO
